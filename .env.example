# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_id   # e.g. -1001234567890
TELEGRAM_RETRIES=3
TELEGRAM_RETRY_DELAY=5

# ── Facebook ───────────────────────────────────────────────────────────────
FACEBOOK_REELS_URL=https://www.facebook.com/nisarmehdiedits/reels/
CHECK_INTERVAL_SECONDS=60

# ── Playwright ─────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PAGE_LOAD_TIMEOUT=30000
SCROLL_PAUSE=2.0
MAX_SCROLL_ROUNDS=5

# ── yt-dlp ─────────────────────────────────────────────────────────────────
YTDLP_RATE_LIMIT=500K

# ── FFmpeg ─────────────────────────────────────────────────────────────────
FFMPEG_THREADS=2
